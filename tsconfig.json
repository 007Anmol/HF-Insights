{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",
    "jsx": "react",
    "strict": true,
    "noImplicitAny": true,
    "moduleResolution": "node16",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@components/*": [
        "src/components/*"
      ],
      "@context/*": [
        "src/context/*"
      ],
      "@utils/*": [
        "src/*"
      ]
    }
  },
  "include": [
    "app",
    "src"
  ],
  "extends": "expo/tsconfig.base"
}
